# MySQL — use "localhost" from host, "mysql" inside this service's docker-compose
DATABASE_URL=mysql+pymysql://map_user:map_pass@mysql:3306/geo_db
DATABASE_TEST_URL=mysql+pymysql://map_user:map_pass@mysql:3306/geo_test_db

FLASK_ENV=development
FLASK_SECRET_KEY=change-me-in-production
PORT=8081

# RabbitMQ — broker/docker-compose.yml exposes 5672 on localhost
# From this app's container, use host.docker.internal (Windows/Mac) or the docker network name
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=bike_network.events
# Routing keys consumed by this service (deployment diagram + product HUs)
RABBITMQ_ROUTING_KEY_BIKE_CREATED=bike.created
RABBITMQ_ROUTING_KEY_BIKE_DELETED=bike.deleted
RABBITMQ_ROUTING_KEY_RENTAL_COMPLETED=rental.completed

# Set to 1 when RabbitMQ is running (e.g. broker/docker-compose.yml)
ENABLE_RABBIT_CONSUMERS=0
